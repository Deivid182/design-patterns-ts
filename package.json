{
  "name": "design-patterns-ts",
  "version": "1.0.0",
  "description": "Colección de patrones de diseño implementados en TypeScript",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "run:file": "tsx watch",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": ["design-patterns", "typescript", "solid", "clean-architecture"],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
